  "components": {
    "schemas": {
      "AnalyzeResponse": {
        "properties": {
          "job_id": {
            "type": "string",
            "title": "Job Id"
          },
          "status": {
            "type": "string",
            "enum": [
              "queued",
              "processing",
              "done",
              "error"
            ],
            "title": "Status"
          },
          "analysis": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/SongAnalysis"
              },
              {
                "type": "null"
              }
            ]
          },
          "instrument_guide": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/InstrumentGuide"
              },
              {
                "type": "null"
              }
            ]
          },
          "error": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Error"
          }
        },
        "type": "object",
        "required": [
          "job_id",
          "status"
        ],
        "title": "AnalyzeResponse"
      },
      "BeatEvent": {
        "properties": {
          "time": {
            "type": "number",
            "title": "Time"
          },
          "beat_number": {
            "type": "integer",
            "title": "Beat Number",
            "description": "1, 2, 3, 4 for 4/4 time"
          }
        },
        "type": "object",
        "required": [
          "time",
          "beat_number"
        ],
        "title": "BeatEvent"
      },
      "Body_analyze_analyze_post": {
        "properties": {
          "youtube_url": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Youtube Url"
          },
          "instrument": {
            "type": "string",
            "title": "Instrument",
            "default": "guitar"
          },
          "difficulty": {
            "type": "string",
            "title": "Difficulty",
            "default": "beginner"
          },
          "user_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "User Id"
          },
          "file": {
            "anyOf": [
              {
                "type": "string",
                "contentMediaType": "application/octet-stream"
              },
              {
                "type": "null"
              }
            ],
            "title": "File"
          }
        },
        "type": "object",
        "title": "Body_analyze_analyze_post"
      },
      "Body_analyze_api_v1_analyze_post": {
        "properties": {
          "youtube_url": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Youtube Url"
          },
          "instrument": {
            "type": "string",
            "title": "Instrument",
            "default": "guitar"
          },
          "difficulty": {
            "type": "string",
            "title": "Difficulty",
            "default": "beginner"
          },
          "user_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "User Id"
          },
          "file": {
            "anyOf": [
              {
                "type": "string",
                "contentMediaType": "application/octet-stream"
              },
              {
                "type": "null"
              }
            ],
            "title": "File"
          }
        },
        "type": "object",
        "title": "Body_analyze_api_v1_analyze_post"
      },
      "ChatRequest": {
        "properties": {
          "message": {
            "type": "string",
            "title": "Message"
          },
          "history": {
            "items": {
              "additionalProperties": true,
              "type": "object"
            },
            "type": "array",
            "title": "History",
            "default": []
          },
          "session_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Session Id"
          },
          "user_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "User Id"
          }
        },
        "type": "object",
        "required": [
          "message"
        ],
        "title": "ChatRequest"
      },
      "ChatResponse": {
        "properties": {
          "reply": {
            "type": "string",
            "title": "Reply"
          }
        },
        "type": "object",
        "required": [
          "reply"
        ],
        "title": "ChatResponse"
      },
      "ChordDiagram": {
        "properties": {
          "chord": {
            "type": "string",
            "title": "Chord"
          },
          "instrument": {
            "type": "string",
            "enum": [
              "guitar",
              "piano",
              "ukulele",
              "bass"
            ],
            "title": "Instrument"
          },
          "frets": {
            "anyOf": [
              {
                "items": {
                  "type": "integer"
                },
                "type": "array"
              },
              {
                "type": "null"
              }
            ],
            "title": "Frets"
          },
          "fingers": {
            "anyOf": [
              {
                "items": {
                  "type": "integer"
                },
                "type": "array"
              },
              {
                "type": "null"
              }
            ],
            "title": "Fingers"
          },
          "right_hand": {
            "anyOf": [
              {
                "items": {
                  "type": "string"
                },
                "type": "array"
              },
              {
                "type": "null"
              }
            ],
            "title": "Right Hand"
          },
          "left_hand": {
            "anyOf": [
              {
                "items": {
                  "type": "string"
                },
                "type": "array"
              },
              {
                "type": "null"
              }
            ],
            "title": "Left Hand"
          }
        },
        "type": "object",
        "required": [
          "chord",
          "instrument"
        ],
        "title": "ChordDiagram",
        "description": "One chord shape for one instrument."
      },
      "ChordEvent": {
        "properties": {
          "start": {
            "type": "number",
            "title": "Start",
            "description": "Start time in seconds"
          },
          "end": {
            "type": "number",
            "title": "End",
            "description": "End time in seconds"
          },
          "chord": {
            "type": "string",
            "title": "Chord",
            "description": "Chord symbol, e.g. 'Cmaj7', 'Am', 'G/B'"
          },
