              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/analyze/{job_id}": {
      "get": {
        "summary": "Get Analysis",
        "description": "Retrieves the current status or completed result of a song analysis job from MongoDB.\n\nPass ``?instrument=guitar`` (etc.) to receive the matching instrument guide;\nomitting it returns no guide rather than an arbitrary one.",
        "operationId": "get_analysis_api_v1_analyze__job_id__get",
        "parameters": [
          {
            "name": "job_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Job Id"
            }
          },
          {
            "name": "instrument",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Instrument"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AnalyzeResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/jobs/{job_id}/progress": {
      "get": {
        "summary": "Get Analysis Progress",
        "description": "Server-Sent Events stream of analysis progress.\n\nProtocol (Plan 2 D6 \u2014 tagged events):\n    event: chunk    data: {status, progress, message, ...}   (repeated)\n    event: done     data: {job_id, status: \"done\", ...}      (terminal)\n    event: error    data: {code, message}                    (terminal)\n\nSuccessful jobs end with ``done``; downstream LLM failure or worker\ncrash ends with ``error``. The frontend ``openProgressStream`` consumer\nin :mod:`frontend/web/src/lib/apiClient.ts` handles both new and legacy\nformats; once it ships, the backend can stop emitting untagged frames.",
        "operationId": "get_analysis_progress_api_v1_jobs__job_id__progress_get",
        "parameters": [
          {
            "name": "job_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Job Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
