# === LLM Provider ===
# Supported: ollama | openai | anthropic | gemini | groq | openrouter
#
# RECOMMENDED FREE SETUP: Groq (primary) -> Gemini (fallback). Both have
# generous no-card free tiers and are fast; structured-output chains use
# function_calling so both work. For Gemini install the provider extra:
#     pip install -e "./backend[providers]"
#   - Groq:   ~30 req/min, 1,000 req/day (14,400 on llama-3.1-8b-instant). console.groq.com
#   - Gemini: ~10 req/min, 250 req/day, 250K TPM. aistudio.google.com
#   - ollama (local, unlimited but slow) is a good offline fallback.
LLM_PROVIDER=groq
# Leave MODEL_NAME empty to use provider defaults (groq -> llama-3.3-70b-versatile).
MODEL_NAME=llama-3.3-70b-versatile
EMBEDDING_MODEL=text-embedding-3-small

# === API Keys (fill in for your chosen provider) ===
OPENAI_API_KEY=sk-your-key-here
ANTHROPIC_API_KEY=sk-ant-your-key-here
GEMINI_API_KEY=your-gemini-key-here
GROQ_API_KEY=gsk_your-key-here
OPENROUTER_API_KEY=sk-or-your-key-here

# === Optional Fallback (auto-tries on primary failure) ===
# Gemini fallback when Groq 429s/errors. Or use openrouter
# (LLM_FALLBACK_MODEL=openai/gpt-oss-20b:free) / ollama (llama3.2, local).
LLM_FALLBACK_PROVIDER=gemini
LLM_FALLBACK_MODEL=gemini-2.5-flash

# === Data Stores ===
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=synesthesia
REDIS_URL=redis://localhost:6379/0

# === Optional Tracing ===
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=soundbreak

# === Storage ===
AUDIO_UPLOAD_DIR=./storage/uploads
STEMS_DIR=./storage/stems

# === App Config ===
MAX_UPLOAD_MB=50
RATE_LIMIT_PER_DAY=10
ENABLE_STEMS=true
LOG_LEVEL=INFO

# --- Chat / AURA (Phase 2) ---
# CHAT_PROVIDER / CHAT_MODEL default to LLM_PROVIDER / MODEL_NAME when blank.
CHAT_PROVIDER=
CHAT_MODEL=
CHAT_TOOLS_ENABLED=true
CHAT_MAX_TOOL_ITERS=4
CHAT_HISTORY_TURNS=10
CHAT_TUTOR_DEFAULT=false
CHAT_USER_DAILY_TOKEN_BUDGET=200000
# Per-user chat rate limit (slowapi syntax). Lower than analyze; keyed by user_id.
CHAT_RATE_LIMIT=30/minute

# Last.fm similar-songs (optional; graceful no-op when unset)
# Free key: https://www.last.fm/api/account/create
# LASTFM_API_KEY=your_key_here
