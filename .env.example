# === LLM Provider ===
# Supported: ollama | openai | anthropic | gemini | groq | openrouter
LLM_PROVIDER=ollama
# Leave MODEL_NAME empty to use provider defaults (e.g. qwen3:8b for ollama)
MODEL_NAME=
EMBEDDING_MODEL=text-embedding-3-small

# === API Keys (fill in for your chosen provider) ===
OPENAI_API_KEY=sk-your-key-here
ANTHROPIC_API_KEY=sk-ant-your-key-here
GEMINI_API_KEY=your-gemini-key-here
GROQ_API_KEY=gsk_your-key-here
OPENROUTER_API_KEY=sk-or-your-key-here

# === Optional Fallback (auto-tries on primary failure) ===
LLM_FALLBACK_PROVIDER=
LLM_FALLBACK_MODEL=

# === Data Stores ===
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=synesthesia
REDIS_URL=redis://localhost:6379/0

# === Optional Tracing ===
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=soundbreak

# === Storage ===
AUDIO_UPLOAD_DIR=./storage/uploads
STEMS_DIR=./storage/stems

# === App Config ===
MAX_UPLOAD_MB=50
RATE_LIMIT_PER_DAY=10
ENABLE_STEMS=true
LOG_LEVEL=INFO
