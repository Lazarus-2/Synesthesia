  "paths": {
    "/health": {
      "get": {
        "summary": "Health",
        "description": "Liveness probe.\n\nCheap and always-200 so orchestrators can use this for \"is the process\nalive\" without depending on downstream services. For dependency state,\nsee :func:`readiness`.",
        "operationId": "health_health_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": true,
                  "type": "object",
                  "title": "Response Health Health Get"
                }
              }
            }
          }
        }
      }
    },
    "/health/ready": {
      "get": {
        "summary": "Readiness",
        "description": "Readiness probe \u2014 pings Mongo and Redis, surfaces per-dependency state.\n\nReturns 200 only when every required dependency is reachable, 503\notherwise with the per-dep breakdown. Use this for Kubernetes\n``readinessProbe`` so traffic doesn't hit a node whose Mongo connection\nis wedged.",
        "operationId": "readiness_health_ready_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    },
    "/api/v1/analyze": {
      "post": {
        "summary": "Analyze",
        "description": "Kicks off the audio chord and theory analysis pipeline.",
        "operationId": "analyze_api_v1_analyze_post",
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/Body_analyze_api_v1_analyze_post"
              }
