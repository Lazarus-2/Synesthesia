                   "roman": {"progression": ["I", "V", "vi", "IV"]}, "title": "Song A", "artist": "Band A"},
      "scripted": [{"answer": "This song is in G major."}],
      "expected": {"tools": [], "grounded_fact": "G major", "forbidden": ["C major", "C minor"]}
    },
